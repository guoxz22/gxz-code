# Copy to .env only for local shell loading tools. GXZ-code itself reads env vars.
# Do not commit real API keys.

# GLM / BigModel. Either name is accepted.
GLM_API_KEY=your_bigmodel_key_here
# BIGMODEL_API_KEY=your_bigmodel_key_here
# ZHIPU_API_KEY=your_bigmodel_key_here

# Defaults for GLM Coding Plan.
GXZ_PROVIDER=glm-openai
GXZ_MODEL=glm-5.1
GLM_OPENAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
GLM_ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# Optional third-party providers.
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com
